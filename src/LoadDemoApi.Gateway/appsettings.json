{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Backend": {
    "Url": "http://localhost:5000"
  },
  "SubscriptionKey": "dev-key",
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "api",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "api": {
        "Destinations": {
          "api": {
            "Address": "http://localhost:5000"
          }
        }
      }
    }
  }
}
